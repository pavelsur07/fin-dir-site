{
  "name": "vashfindir/site",
  "type": "project",
  "require": {
    "php": ">=8.3",
    "symfony/framework-bundle": "7.4.*",
    "symfony/console": "7.4.*",
    "symfony/twig-bundle": "7.4.*",
    "symfony/runtime": "7.4.*",
    "symfony/yaml": "7.4.*",
    "symfony/string": "7.4.*",
    "symfony/flex": "^2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "extra": {
    "public-dir": "public"
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    }
  },
  "description": "Vashfindir Symfony site application",
  "license": "proprietary"
}
